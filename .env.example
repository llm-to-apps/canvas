PORT=4121
CANVAS_PUBLIC_BASE_URL=http://localhost:4121
DATABASE_URL=postgresql://canvas:canvas@localhost:8082/canvas
CANVAS_SCRIPT_SRC="'unsafe-inline' https://cdn.jsdelivr.net https://unpkg.com https://cdn.tailwindcss.com"
CANVAS_STYLE_SRC="'unsafe-inline' https://cdn.jsdelivr.net https://unpkg.com"
CANVAS_CONNECT_SRC="'none'"

CANVAS_S3_ENDPOINT=http://localhost:8333
CANVAS_S3_INTERNAL_ENDPOINT=http://localhost:8333
CANVAS_S3_REGION=us-east-1
CANVAS_S3_BUCKET=canvas
CANVAS_S3_ACCESS_KEY_ID=os7-local-access-key
CANVAS_S3_SECRET_ACCESS_KEY=os7-local-secret-key-change-me
CANVAS_S3_FORCE_PATH_STYLE=true

AGENT_RUNTIME_URL=http://localhost:4111
CANVAS_INTERNAL_TOKEN=dev-canvas-internal-token-change-me
