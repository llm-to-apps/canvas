{
  "name": "@os7/canvas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && tsc",
    "db:test:reset": "rm -f prisma/test.db prisma/test.db-journal && DATABASE_URL=file:./test.db npm run prisma:generate && RUST_LOG=info DATABASE_URL=file:./test.db node scripts/prisma.mjs db push --skip-generate",
    "dev": "tsx watch src/server.ts",
    "prisma:generate": "node scripts/prisma.mjs generate",
    "prisma:migrate:deploy": "node scripts/prisma.mjs migrate deploy",
    "prisma:migrate:dev": "node scripts/prisma.mjs migrate dev",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "npm run db:test:reset && DATABASE_URL=file:./test.db vitest run; status=$?; npm run prisma:generate; exit $status"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1071.0",
    "@hono/node-server": "^1.19.14",
    "@prisma/client": "^6.19.3",
    "dotenv": "^17.3.1",
    "hono": "^4.10.7",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "prisma": "^6.19.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
